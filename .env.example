# Supabase Configuration
# Get these values from your Supabase project settings
# IMPORTANT: Use the JWT anon key (starts with "eyJ..."), NOT the publishable key (starts with "sb_publishable_")
# Get the anon key with: supabase projects api-keys --project-ref YOUR_PROJECT_REF
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Web Push (VAPID) Configuration
# Generate keys with: npx web-push generate-vapid-keys
# The public key is safe to expose in frontend code
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# AWS Bedrock (for AI features: image analysis, embeddings, shopping assistant)
# Create an IAM user with AmazonBedrockFullAccess policy
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# Stripe key from dashboard
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...